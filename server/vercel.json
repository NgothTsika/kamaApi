{
  "buildCommand": "cd server && yarn generate && yarn build",
  "outputDirectory": "server/dist",
  "framework": "express",
  "functions": {
    "server/dist/api/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/dist/api/index.js"
    }
  ]
}
